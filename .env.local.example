# Supabase (from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=
# Use either key name — both are supported
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# YouTube Data API v3 — server-side only, never prefix with NEXT_PUBLIC_
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Optional: Supabase Service Role key for server-side admin operations
# Only needed if you want server-side inserts that bypass RLS
# SUPABASE_SERVICE_ROLE_KEY=
